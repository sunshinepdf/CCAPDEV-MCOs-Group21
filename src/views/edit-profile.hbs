{{!
  ### `src/views/edit-profile.hbs`
  - Edit profile form page.
  - Provides editable fields for username, bio, pronouns, year, major, tags, and profile photo upload trigger.
  - Uses `edit-profile.js` behavior wiring via route flags.

  Edit Profile page template
  Allows users to edit their profile information, including name, bio, pronouns, year, major, and tags
}}
<div class="main-content">
  <style>
    .tag-remove { display: inline !important; }
    .tag-input { display: inline-flex !important; }
  </style>

  <div class="container">
    <nav-bar active="profile"></nav-bar>

    <div class="page-section" style="--page-color: #504e76;">
      <div class="content-box" style="--content-bg: #fdf8e2;">
        <div class="profile-topbar">
          <div class="profile-title">
            <img src="assets/profile-icon.png" alt="profile" width="20" height="20">
            <h1 class="poppins-extrabold">Edit Profile</h1>
          </div>
        </div>

        <div class="user-profile-header">
          <div class="profile-avatar">
            <img
              src="assets/profile-icon-default.png"
              alt="Profile photo"
              id="user-profile-photo"
              width="120"
              height="120"
              style="border-radius: 50%; object-fit: cover; border: 2px solid #504e76;"
            >

            <label class="btn-edit-pfp" for="upload-profile-photo">
              <img src="assets/edit-image.png" alt="Edit photo" width="12" height="12">
            </label>

            <input type="file" id="upload-profile-photo" accept="image/*" style="display: none;">
          </div>

          <div class="profile-info">
            <div class="profile-actions">
              <button class="btn-edit-profile poppins-extrabold" id="save-profile-edits" type="button">
                Save Changes
              </button>
              <button class="btn-reset-profile poppins-extrabold" id="reset-profile-to-default" type="button">
                Reset
              </button>
            </div>

            <div class="profile-content">
              <input
                type="text"
                class="poppins-extrabold"
                id="edit-name"
                value="Username"
                style="font-size: 24px; border: 2px solid #504e76; padding: 8px; border-radius: 8px; width: 100%;"
              >

              <textarea
                class="poppins-regular"
                id="edit-bio"
                placeholder="This is a sample bio for the user profile..."
                style="font-size: 14px; border: 2px solid #504e76; padding: 8px; border-radius: 8px; width: 100%; margin-top: 10px; font-family: Poppins; min-height: 100px; resize: vertical;"
              ></textarea>

              <div class="profile-content" style="padding: 0; margin-top: 14px;">
                <select
                  class="poppins-regular"
                  id="edit-pronouns"
                  style="font-size: 14px; border: 2px solid #504e76; padding: 8px; border-radius: 8px; width: 100%; background-color: #fdf8e2;"
                >
                  <option value="She/Her">She/Her</option>
                  <option value="He/Him">He/Him</option>
                  <option value="They/Them">They/Them</option>
                  <option value="Other">Other</option>
                </select>

                <select
                  class="poppins-regular"
                  id="edit-year"
                  style="font-size: 14px; border: 2px solid #504e76; padding: 8px; border-radius: 8px; width: 100%; margin-top: 10px; background-color: #fdf8e2;"
                >
                  <option value="1st Year">1st Year</option>
                  <option value="2nd Year">2nd Year</option>
                  <option value="3rd Year">3rd Year</option>
                  <option value="4th Year">4th Year</option>
                  <option value="5th Year">5th Year</option>
                </select>

                <input
                  type="text"
                  class="poppins-regular"
                  id="edit-major"
                  placeholder="Major"
                  style="font-size: 14px; border: 2px solid #504e76; padding: 8px; border-radius: 8px; width: 100%; margin-top: 10px;"
                >
              </div>

              <div class="profile-tags" id="edit-tags" style="margin-top: 16px;"></div>

              <section class="profile-security-section">
                <h3 class="poppins-extrabold">Change Password</h3>
                <p class="poppins-regular profile-security-help">Leave these blank if you do not want to change your password.</p>

                <div class="password-field password-field--profile">
                  <input
                    type="password"
                    class="poppins-regular profile-edit-input"
                    id="edit-current-password"
                    placeholder="Current password"
                    autocomplete="current-password"
                  >
                  <button type="button" class="password-toggle-btn poppins-regular" data-toggle-password="edit-current-password" aria-label="Show current password">Show</button>
                </div>

                <div class="password-field password-field--profile">
                  <input
                    type="password"
                    class="poppins-regular profile-edit-input"
                    id="edit-new-password"
                    placeholder="New password"
                    autocomplete="new-password"
                  >
                  <button type="button" class="password-toggle-btn poppins-regular" data-toggle-password="edit-new-password" aria-label="Show new password">Show</button>
                </div>

                <div class="password-field password-field--profile">
                  <input
                    type="password"
                    class="poppins-regular profile-edit-input"
                    id="edit-confirm-password"
                    placeholder="Confirm new password"
                    autocomplete="new-password"
                  >
                  <button type="button" class="password-toggle-btn poppins-regular" data-toggle-password="edit-confirm-password" aria-label="Show confirm password">Show</button>
                </div>
              </section>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>
