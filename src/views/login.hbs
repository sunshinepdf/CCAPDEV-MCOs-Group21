{{!
  ### `src/views/login.hbs`
  - Login page form template.
  - Collects username/password + remember-me state.
  - Provides navigation to sign-up and guest-home entry.

  Login page template
  Provides a login form for users to access their accounts
}}
<div class="login-container">
  <div class="login-side-banner">
    <h2 class="poppins-extrabold">Welcome back Archer!</h2>
    <p class="poppins-regular">Ready to discover and explore what the Commons is up to today?</p>
  </div>
  <div class="login-form-container">
    <div class="login-form">
      <div class="login-form-header">
        <img src="assets/logo.png" alt="AnimoCommons Logo" width="200x" height="200px">
      </div>
      <h1 class="poppins-extrabold">Login</h1>
      <form id="login-form">
        <input type="text" id="username" placeholder="Username" required>
        <div class="password-field password-field--login">
          <input type="password" id="password" placeholder="Password" required>
          <button type="button" class="password-toggle-btn poppins-regular" data-toggle-password="password" aria-label="Show password">Show</button>
        </div>
        <button type="submit" class="poppins-regular login-submit-btn">Login</button>
        <div class="remember-me-container">
          <input type="checkbox" id="remember-me" name="remember-me">
          <label for="remember-me" class="poppins-regular">Remember Me</label>
        </div>
        <div class="forgot-password-row">
          <button type="button" id="forgot-password-toggle" class="poppins-regular forgot-password-toggle">Forgot password?</button>
        </div>
        <div id="forgot-password-panel" class="forgot-password-panel" style="display:none;">
          <p class="poppins-regular forgot-password-help">Reset your password using your username or email.</p>
          <input type="text" id="forgot-username" placeholder="Username or email">
          <div class="password-field password-field--login">
            <input type="password" id="forgot-new-password" placeholder="New password" autocomplete="new-password">
            <button type="button" class="password-toggle-btn poppins-regular" data-toggle-password="forgot-new-password" aria-label="Show new password">Show</button>
          </div>
          <div class="password-field password-field--login">
            <input type="password" id="forgot-confirm-password" placeholder="Confirm new password" autocomplete="new-password">
            <button type="button" class="password-toggle-btn poppins-regular" data-toggle-password="forgot-confirm-password" aria-label="Show confirm password">Show</button>
          </div>
          <button type="button" id="forgot-password-submit" class="poppins-regular forgot-password-submit">Reset Password</button>
        </div>
      </form>
      <p class="poppins-regular">Don't have an account? <a href="/sign-up" class="poppins-regular">Sign up here</a></p>
      <p class="poppins-regular"><a href="/home" class="poppins-regular">Continue as Guest</a></p>
    </div>
  </div>
</div>
