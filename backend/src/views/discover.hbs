{{! 
  ### `src/views/discover.hbs`
  - Discover page layout.
  - Contains search bar, category filter overlay, posts grid, and single-post container.
  - Includes post modal partial.

  Discover page template
  Displays a grid of posts with search and filter functionality
}}
<div class="main-content">
  <header-component></header-component>
  <global-sidebar></global-sidebar>
  <div class="container">
    <nav-bar active="discover"></nav-bar>

    <div class="page-section" style="--page-color: #f1b02e;">
      <div class="content-box" style="--content-bg: #fdf8e2;">

        <div class="discover-topbar">
          <div class="discover-title">
            <img src="assets/discover-icon.png" alt="discover" width="20" height="20">
            <div class="title-group">
              <h1 class="poppins-extrabold">Discover Posts</h1>
              <div id="discoverDate" class="masthead-sub poppins-regular">—</div>
            </div>
          </div>
        </div>

        <div class="discover-controls">
          <div class="search-filter-wrapper">
            <search-bar placeholder="Search posts..." target=".article"></search-bar>
            <button class="filter-btn" onclick="toggleFilter()">
              <img src="assets/filter-icon.png" alt="Filter">
            </button>
          </div>
        </div>

        <div class="paper-grid" id="discoverPosts"></div>
        <div id="singlePostView" style="display:none;"></div>
      </div>
    </div>
  </div>
</div>

<div class="filter-overlay" id="filterOverlay">
  <div class="filter-panel" id="filterPanel">
    <h4>Filter by Category</h4>
    <div id="dynamicFilters"></div>
    <div class="filter-actions">
      <button onclick="applyFilters()">Filter</button>
    </div>
  </div>
</div>

{{> post-view-modal}}
