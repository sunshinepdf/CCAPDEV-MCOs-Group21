{{!
  ### `src/views/sign-up.hbs`
  - Sign-up form template.
  - Collects username/email/password and links back to login.

  Sign Up page template
  Provides a registration form for new users to create an account
}}
<div class="sign-up-container">
  <div class="sign-up-banner">
    <h2 class="poppins-extrabold">Join the Commons, Archer!</h2>
    <p class="poppins-regular">Discover and explore what the Commons is up to today!</p>
  </div>
  <div class="sign-up-form-container">
    <div class="sign-up-form">
      <h1 class="poppins-extrabold">Sign Up</h1>
      <form id="sign-up-form">
        <div class="form-columns">
          <!-- Left Column -->
          <div class="form-col">
            <div class="input-group">
              <label class="poppins-regular" for="username">Username <span style="color: #4CAF50;">*</span></label>
              <input type="text" id="username" placeholder="Enter your username" required maxlength="20">
              <span id="username-feedback" class="poppins-regular" style="font-size: 13px; font-weight: bold; margin-top: 2px; display: block; text-align: left;"></span>
            </div>
            <div class="input-group">
              <label class="poppins-regular" for="email">DLSU Email <span style="color: #4CAF50;">*</span></label>
              <input type="email" id="email" placeholder="Enter your DLSU email (name@dlsu.edu.ph)" required maxlength="100">
              <span id="email-feedback" class="poppins-regular" style="font-size: 13px; font-weight: bold; margin-top: 2px; display: block; text-align: left;"></span>
            </div>
            <div class="input-group">
              <label class="poppins-regular" for="password">Password <span style="color: #4CAF50;">*</span></label>
              <div class="password-field">
                <input type="password" id="password" placeholder="Create a password" required maxlength="128">
                <button type="button" class="password-toggle-btn poppins-regular" data-toggle-password="password" aria-label="Show password">Show</button>
              </div>
              <p class="poppins-regular" style="font-size: 13px; font-style: italic; margin-top: 0; text-align: left;">
                At least 8 characters long, with at least one uppercase letter, one lowercase letter, and one number.
              </p>
            </div>
            <div class="input-group">
              <label class="poppins-regular" for="confirm-password">Confirm Password <span style="color: #4CAF50;">*</span></label>
              <div class="password-field">
                <input type="password" id="confirm-password" placeholder="Confirm password" required maxlength="128">
                <button type="button" class="password-toggle-btn poppins-regular" data-toggle-password="confirm-password" aria-label="Show password">Show</button>
              </div>
            </div>
          </div>
          <!-- Right Column -->
          <div class="form-col">
            <div class="input-group">
              <label class="poppins-regular" for="year">Year Level</label>
              <select id="year" class="poppins-regular">
                <option value="" disabled selected>Select your year level</option>
                <option value="1st Year">1st Year</option>
                <option value="2nd Year">2nd Year</option>
                <option value="3rd Year">3rd Year</option>
                <option value="4th Year">4th Year</option>
                <option value="5th Year+">5th Year+</option>
              </select>
            </div>
            <div class="input-group">
              <label class="poppins-regular" for="major">Major</label>
              <input type="text" id="major" list="major-options" placeholder="Select or type your major" maxlength="150">
              <datalist id="major-options">
                <!-- Dynamically populated from /degrees.json -->
              </datalist>
            </div>
            <div class="input-group">
              <label class="poppins-regular" for="pronouns">Pronouns</label>
              <input type="text" id="pronouns" placeholder="e.g. they/them, he/him, she/her" maxlength="20">
            </div>
            <div class="input-group">
              <label class="poppins-regular" for="profile-pic">Profile Picture</label>
              <input type="file" id="profile-pic" accept=".png, .jpg, .jpeg, image/png, image/jpeg">
              <p class="poppins-regular" style="font-size: 13px; font-style: italic; margin-top: 0; text-align: left;">
                Optional. Max size: 2MB. (.png, .jpg, .jpeg)
              </p>
            </div>
          </div>
        </div>
        <button type="submit" class="poppins-regular submit-btn">Sign Up</button>
      </form>
      <p class="poppins-regular">Already have an account? <a href="/login" class="poppins-regular">Login here</a></p>
    </div>
  </div>
</div>
